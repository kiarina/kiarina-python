# This file defines the configurations and flags to enable tests for each package when running `mise run package:test`.
# Note that similar .env.sample files exist under each package directory; those are used when running pytest directly from IDEs like VSCode.

# kiarina-lib-cloudflare-d1
KIARINA_LIB_CLOUDFLARE_D1_TEST_SETTINGS_FILE=./packages/kiarina-lib-cloudflare-d1/test_settings.yaml
# kiarina-lib-firebase
KIARINA_LIB_FIREBASE_TEST_SETTINGS_FILE=./packages/kiarina-lib-firebase/test_settings.yaml
# kiarina-lib-firebase-rtdb
KIARINA_LIB_FIREBASE_RTDB_TEST_SETTINGS_FILE=./packages/kiarina-lib-firebase-rtdb/test_settings.yaml
KIARINA_LIB_FIREBASE_RTDB_TEST_DATABASE_URL=https://<your-database-name>.firebaseio.com/
# kiarina-lib-google
KIARINA_LIB_GOOGLE_TEST_SETTINGS_FILE=./packages/kiarina-lib-google/test_settings.yaml
