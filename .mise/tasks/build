#!/usr/bin/env bash
#MISE description="Build packages (all, or a single [package])"
#USAGE arg "[package]" help="Package name (default: current package, or all at repo root)"

set -euo pipefail

target="${usage_package:-$(cd "${MISE_ORIGINAL_CWD:-$PWD}" && mise run package:current)}"

# Resolve "all" by recursing once per package (meta-packages included).
if [ "$target" = "all" ]; then
    while IFS= read -r package; do
        mise run build "$package"
    done < <(mise run package:list --all)
    exit 0
fi

# Single-package build.
if [ ! -d "packages/$target" ]; then
    echo "❌ Package not found: $target" >&2
    exit 1
fi

echo "🏗️  Building $target..."

cd "packages/$target"
uv build
cd - > /dev/null

echo "✅ $target built successfully!"
echo "📁 Built package is in packages/$target/dist/ directory"
