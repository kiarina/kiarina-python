#!/usr/bin/env bash
#MISE description="Run CI checks (setup, all:lint, all:test, all:build)"
#USAGE flag "--no-setup" help="Skip setup step (useful when environment is already prepared)"
#USAGE flag "--no-docker" help="Skip Docker Compose up/down during testing"

set -euo pipefail

no_setup="${usage_no_setup:-false}"
no_docker="${usage_no_docker:-false}"

echo "🚀 Running CI checks for all packages..."

if [ "$no_setup" = "false" ]; then
    echo ""
    echo "🔧 Step 1/4: Setup environment..."
    mise run setup
else
    echo ""
    echo "⏭️  Skipping setup step..."
fi

echo ""
echo "🔍 Step 2/4: Lint check..."
mise run all:lint

echo ""
echo "🧪 Step 3/4: Test..."
if [ "$no_docker" = "true" ]; then
    mise run all:test --coverage --no-docker
else
    mise run all:test --coverage
fi

echo ""
echo "🏗️  Step 4/4: Build check..."
mise run all:build

echo ""
echo "✅ All CI checks passed!"
