#!/usr/bin/env bash
#MISE description="Format and auto-fix lint issues (all, or a single [package])"
#USAGE arg "[package]" help="Package name (default: current package, or all at repo root)"
#USAGE flag "--unsafe" help="Apply Ruff unsafe fixes"

set -euo pipefail

target="${usage_package:-$(cd "${MISE_ORIGINAL_CWD:-$PWD}" && mise run package:current)}"
unsafe="${usage_unsafe:-false}"

# Resolve "all" by recursing once per package (meta-packages excluded).
if [ "$target" = "all" ]; then
    while IFS= read -r package; do
        if [ "$unsafe" = "true" ]; then
            mise run format "$package" --unsafe
        else
            mise run format "$package"
        fi
    done < <(mise run package:list)
    exit 0
fi

# Single-package format.
if [ ! -d "packages/$target" ]; then
    echo "❌ Package not found: $target" >&2
    exit 1
fi

echo "⚙️ Formatting $target..."

paths=()
if [ -d "packages/$target/src" ]; then
    paths+=("packages/$target/src/")
fi

if [ -d "packages/$target/tests" ]; then
    paths+=("packages/$target/tests/")
fi

if [ ${#paths[@]} -eq 0 ]; then
    echo "⚠️  No src or tests directories found for $target"
    exit 0
fi

echo "🔧 Running ruff check with auto-fix..."
ruff_check_args=(check "${paths[@]}" --fix)
if [ "$unsafe" = "true" ]; then
    ruff_check_args+=(--unsafe-fixes)
fi
uv run --group dev ruff "${ruff_check_args[@]}"

echo "🔧 Running ruff format..."
uv run --group dev ruff format "${paths[@]}"
