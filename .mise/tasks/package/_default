#!/usr/bin/env bash
#MISE description="Choose and run a package task"

set -euo pipefail

if ! command -v fzf >/dev/null 2>&1; then
    echo "❌ fzf is required to select a package task interactively." >&2
    exit 1
fi

task="$(
    printf '%s\n' build check clean format lint publish test |
        fzf --prompt="Package task> " --height=40% --border
)"

if [ -z "$task" ]; then
    echo "❌ No package task selected." >&2
    exit 1
fi

if [[ "$task" == *$'\n'* ]]; then
    echo "❌ Select exactly one package task." >&2
    exit 1
fi

mise run "package:$task"
