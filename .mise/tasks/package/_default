#!/usr/bin/env bash
#MISE description="Choose and run a package task"

set -euo pipefail

if ! command -v fzf >/dev/null 2>&1; then
    echo "❌ fzf is required to select a package and task interactively." >&2
    exit 1
fi

package="$(mise run package:select --all)"

if [ "$package" = "kiarina" ]; then
    tasks=(build clean publish)
else
    tasks=(build check clean format lint publish test)
fi

task="$(
    printf '%s\n' "${tasks[@]}" |
        fzf --prompt="Package task> " --height=40% --border
)"

if [ -z "$task" ]; then
    echo "❌ No package task selected." >&2
    exit 1
fi

if [[ "$task" == *$'\n'* ]]; then
    echo "❌ Select exactly one package task." >&2
    exit 1
fi

mise run "package:$task" "$package"
