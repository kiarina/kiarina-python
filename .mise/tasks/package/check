#!/usr/bin/env bash
#MISE description="Run format, lint, and test with coverage for [package]"
#USAGE arg "[package]" help="Package name (e.g. 'kiarina-utils-common')"

set -euo pipefail

package="${usage_package:-}"

if [ -z "$package" ]; then
    package="$(mise run package:select)"
fi

package="$(basename "$package")"

mise run package:format "$package"
mise run package:lint "$package"
mise run package:test "$package" --coverage
