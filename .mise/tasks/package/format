#!/usr/bin/env bash
#MISE description="Format and auto-fix lint issues for [package]"
#USAGE arg "[package]" help="Package name (e.g. 'kiarina-utils-common')"
#USAGE flag "--unsafe" help="Apply Ruff unsafe fixes"

set -euo pipefail

package="${usage_package:-}"
unsafe="${usage_unsafe:-false}"

if [ -z "$package" ]; then
    package="$(mise run select-package)"
fi

# Package name validation
if [ ! -d "packages/$package" ]; then
    echo "❌ Package not found: $package"
    exit 1
fi

echo "⚙️ Formatting $package..."

paths=()
if [ -d "packages/$package/src" ]; then
    paths+=("packages/$package/src/")
fi

if [ -d "packages/$package/tests" ]; then
    paths+=("packages/$package/tests/")
fi

if [ ${#paths[@]} -eq 0 ]; then
    echo "⚠️  No src or tests directories found for $package"
    exit 0
fi

echo "🔧 Running ruff check with auto-fix..."
ruff_check_args=(check "${paths[@]}" --fix)
if [ "$unsafe" = "true" ]; then
    ruff_check_args+=(--unsafe-fixes)
fi
uv run --group dev ruff "${ruff_check_args[@]}"

echo "🔧 Running ruff format..."
uv run --group dev ruff format "${paths[@]}"
