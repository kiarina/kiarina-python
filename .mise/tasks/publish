#!/usr/bin/env bash
#MISE description="Publish packages to PyPI (all, or a single [package])"
#USAGE arg "[package]" help="Package name (default: current package, or all at repo root)"
#USAGE flag "-t --test" help="Publish to Test PyPI instead of PyPI"

set -euo pipefail

target="${usage_package:-$(cd "${MISE_ORIGINAL_CWD:-$PWD}" && mise run package:current)}"
test_pypi="${usage_test:-false}"

# Resolve "all" by recursing once per package (meta-packages included).
if [ "$target" = "all" ]; then
    while IFS= read -r package; do
        if [ "$test_pypi" = "true" ]; then
            mise run publish "$package" --test
        else
            mise run publish "$package"
        fi
    done < <(mise run package:list --all)
    exit 0
fi

# Single-package publish.
if [ ! -d "packages/$target" ]; then
    echo "❌ Package not found: $target" >&2
    exit 1
fi

echo "📦 Publishing $target..."

cd "packages/$target"

if [ "$test_pypi" = "true" ]; then
    echo "🧪 Publishing to Test PyPI..."
    uv publish --repository testpypi
    echo "✅ $target published to Test PyPI successfully!"
    echo "🔗 Check your package at: https://test.pypi.org/project/$target/"
else
    echo "🚀 Publishing to PyPI..."
    uv publish
    echo "✅ $target published to PyPI successfully!"
    echo "🔗 Check your package at: https://pypi.org/project/$target/"
fi

cd - > /dev/null
