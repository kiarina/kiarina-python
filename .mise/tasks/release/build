#!/usr/bin/env bash
#MISE description="Build packages selected for a release"
#USAGE arg "<version>" help="Release version (e.g. '2.2.0')"

set -euo pipefail

version="$usage_version"

rm -rf dist
mkdir -p dist

while IFS= read -r package; do
    echo "🏗️  Building $package $version..."
    uv build "packages/$package" --out-dir dist
done < <(mise run package:list --release "$version")

if ! find dist -type f \( -name '*.whl' -o -name '*.tar.gz' \) -print -quit | grep -q .; then
    echo "❌ No release artifacts were built" >&2
    exit 1
fi

echo "✅ Release artifacts built in dist/"
