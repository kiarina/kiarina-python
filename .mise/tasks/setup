#!/usr/bin/env bash
#MISE description="Setup development environment (install tools and sync dependencies)"

set -euo pipefail

echo "🚀 Setting up development environment..."

echo ""
echo "📦 Step 1/3: Installing mise tools..."
mise install

echo ""
echo "🔄 Step 2/3: Syncing dependencies..."
uv sync --all-packages --all-extras --all-groups

echo ""
echo "📥 Step 3/3: Downloading test assets..."
mise run test-assets:download

echo ""
echo "✅ Development environment setup complete!"
echo ""
echo "💡 Next steps:"
echo "   - Run 'mise run ci' to verify everything works"
