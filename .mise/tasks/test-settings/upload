#!/usr/bin/env bash
#MISE description="Encrypt and upload test settings to Google Cloud Storage"
#USAGE flag "--dry-run" help="Show files and destinations without encrypting or uploading"

set -euo pipefail

dry_run="${usage_dry_run:-false}"

require_env() {
    local name="$1"

    if [ -z "${!name:-}" ]; then
        echo "❌ Environment variable $name is required." >&2
        exit 1
    fi
}

require_command() {
    local name="$1"

    if ! command -v "$name" >/dev/null 2>&1; then
        echo "❌ Required command not found: $name" >&2
        exit 1
    fi
}

require_env "KIARINA_TEST_SETTINGS_GCS_URI"
require_env "KIARINA_TEST_SETTINGS_AGE_RECIPIENT"

gcs_uri="${KIARINA_TEST_SETTINGS_GCS_URI%/}"
recipient="$KIARINA_TEST_SETTINGS_AGE_RECIPIENT"

if ! [[ "$gcs_uri" =~ ^gs://[^/]+(/.*)?$ ]]; then
    echo "❌ KIARINA_TEST_SETTINGS_GCS_URI must contain a bucket name." >&2
    exit 1
fi

case "$gcs_uri" in
    *'*'*|*'?'*|*'['*)
        echo "❌ KIARINA_TEST_SETTINGS_GCS_URI must not contain wildcards." >&2
        exit 1
        ;;
esac

gcs_path="${gcs_uri#gs://}"
if [[ "$gcs_path" == *'//'* ]]; then
    echo "❌ KIARINA_TEST_SETTINGS_GCS_URI contains an empty path segment." >&2
    exit 1
fi

if [ "$dry_run" = "false" ]; then
    require_command "age"
    require_command "gcloud"
fi

repository_root="$(git rev-parse --show-toplevel)"
cd "$repository_root"

settings_files=()
while IFS= read -r -d '' path; do
    relative_path="${path#./}"
    settings_files+=("$relative_path")
done < <(
    find . \
        \( -path './.git' -o -path './.venv' -o -path './tests/assets' \) -prune -o \
        -type f \( -name '.env' -o -name 'test_settings.yaml' \) -print0
)

if [ "${#settings_files[@]}" -eq 0 ]; then
    echo "❌ No .env or test_settings.yaml files found." >&2
    exit 1
fi

for relative_path in "${settings_files[@]}"; do
    if ! git check-ignore -q -- "$relative_path"; then
        echo "❌ Refusing to upload a file that is not ignored by Git: $relative_path" >&2
        exit 1
    fi
done

echo "🔐 Test settings selected for upload:"
for relative_path in "${settings_files[@]}"; do
    echo "   $relative_path -> $gcs_uri/$relative_path.age"
done

if [ "$dry_run" = "true" ]; then
    echo "✅ Dry run completed. No files were encrypted or uploaded."
    exit 0
fi

staging_dir="$(mktemp -d)"
trap 'rm -rf "$staging_dir"' EXIT

for relative_path in "${settings_files[@]}"; do
    encrypted_path="$staging_dir/$relative_path.age"
    mkdir -p "$(dirname "$encrypted_path")"

    age \
        --encrypt \
        --recipient "$recipient" \
        --output "$encrypted_path" \
        "$relative_path"

    gcloud storage cp \
        "$encrypted_path" \
        "$gcs_uri/$relative_path.age"
done

echo "✅ Encrypted and uploaded ${#settings_files[@]} test settings file(s)."
