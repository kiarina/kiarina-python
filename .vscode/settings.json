{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.egg-info": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.coverage": true,
    "**/coverage.xml": true
  },
  "files.associations": {
    ".mise/tasks/*": "shellscript",
    ".mise/tasks/**/*": "shellscript",
    "format": "shellscript",
    "list": "shellscript",
    "version": "shellscript"
  }
}
